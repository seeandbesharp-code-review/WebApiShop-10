{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "new_connection": "YOUR_DB_CONNECTION_STRING",
    "Redis": "YOUR_REDIS_CONNECTION_STRING"
  },

  "Redis": {
    "TTL": 30
  },

  "Jwt": {
    "Key": "YOUR_SECRET_KEY",
    "Issuer": "WebAPIShop",
    "Audience": "WebAPIShopUsers"
  },

  "Kafka": {
    "BootstrapServers": "YOUR_KAFKA_BOOTSTRAP_SERVERS",
    "Topic": "orders"
  }
}
